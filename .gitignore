# Generated index files
.codebase-index.json
.codebase-intelligence.json

# Build artifacts
artifacts/
coverage.xml
.coverage
testResults.xml

# Transient eval artifacts (ADR-057): re-runnable, not source of truth
.agents/audit/eval-*/

# Transient PR-creation validation-skip audit logs: one record per
# `new_pr.py --skip-validation` invocation; reproducible from git
# history + hook output, not source of truth.
.agents/audit/pr-creation-skip-*.txt

# Runtime caches
.cache/

# Doc-accuracy gate output (transient per-target scratch dirs left
# behind by .claude/skills/doc-accuracy; reproducible from `--target`
# at run time, not source of truth).
.doc-accuracy/
**/.doc-accuracy/

# Claude memory backups (auto-generated by claude-mem plugin; not
# source of truth, regenerable from session logs).
.claude-mem/backups/*.json

# SARIF security-scan outputs (CodeQL, semgrep, etc.). always tool
# output, never authored.
*.sarif

# Python (ADR-042)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
ENV/
.mypy_cache/
.pytest_cache/
.pytest_tmp/
.ruff_cache/
# Anchored to repo root: the legacy python build/dist outputs live at /build
# and /dist. An unanchored `build/` rule silently shadowed
# `src/copilot-cli/skills/build/` (the M4 generated `/build` slash-command
# skill), which made local file-counts diverge from CI.
/dist/
/build/

# Agent PR scratch files
.agents/pr-comments/
.agents/scratch/
.agents/temp/
.agents/logs/
.agents/.hook-state/

# Hook runtime logs and caches
.claude/hooks/audit.log
.claude/hooks/Stop/.skill_pattern_cache.json

# Scheduled-task runtime lock (held while ScheduleWakeup-managed loops run)
.claude/scheduled_tasks.lock

# IDE settings
.idea/
*.DotSettings.user

# Obsidian workspace (user-specific state)
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json

# Git worktrees (isolated development branches)
.work-*/
worktree-*/
worktree--/

# Flowbaby files
.flowbaby/

# Local environment configuration
.env*

# Factory.ai (DROID)
.factory/
# Claude hook runtime state
/.agents/.hook-state/

# Forgetful temporary files
.forgetful/exports/*.bak
.forgetful/exports/*.tmp
.forgetful/exports/*.swp

# CodeQL artifacts
.codeql/cli/
.codeql/db/
.codeql/results/
.codeql/logs/

# Traceability cache
.agents/.cache/

# Memory sync runtime state (Issue #747)
.memory_sync_queue.json
.memory_sync_state.json

.claude/worktrees/

# Node / Bun (packages/)
node_modules/
bun.lockb
*.tgz
