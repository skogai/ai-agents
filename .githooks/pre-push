# ============================================================================
# Phase 5c: Bot-cascade warning (REQ-009-10, REQ-011, issue #1991)
# ============================================================================
# Warn (NOT block) when the current branch's PR has open bot threads OR a
# bot review submitted within the last 120 seconds (scan likely in flight).
# Each push triggers fresh bot scans from Copilot, Cursor, Devin,
# CodeRabbit. Without this warning, the developer often re-pushes before
# bots settle and triggers another cascade. PR #1965 retrospective named
# this as the highest-leverage retro intervention (~20 commits saved).
#
# Warn-only. Never calls record_fail. Bypass via `git push --no-verify`
# (existing escape hatch).
#
# Three contracts derived from PR #1989 M5 implementation defects:
# 1. Require fetched_pages_complete=true before trusting unresolved_count
#    (REQ-011-02). PR #1965 cb1bdf19 had this fix retroactively.
# 2. Recent bot review under 120s emits warn (REQ-011-03). PR #1989's M5
#    omitted this; REQ-009-11 was added after coderabbit caught it. The
#    120-second threshold tracks Copilot/Devin webhook latencies observed
#    during PR #1965 and PR #2004 (30 to 120 seconds); see DESIGN-011
#    trade-off 2 and REQ-011 line 145 (which mandates this inline citation).
# 3. No `|| true` fail-open on reviews query (REQ-011-04). PR #1989's M5
#    had `gh api ... || true` that swallowed auth failures as false PASS.
echo_phase "Phase 5c: Bot-cascade warning"

if ! command -v gh >/dev/null 2>&1; then
    record_skip "Bot-cascade check (gh not available)"
elif ! set_python_cmd; then
    record_skip "Bot-cascade check (no python interpreter found)"
else
    # REQ-011-04 (generalized): distinguish "no PR for branch" (legitimate
    # skip) from "gh pr view failed" (auth/network/transient). Capture
    # stderr+exit. Empty PR_NUMBER with success means no PR; nonzero exit
    # means we cannot trust the result.
    PR_VIEW_STDERR=$(mktemp)
    TEMP_FILES+=("$PR_VIEW_STDERR")
    PR_NUMBER=$(gh pr view --json number --jq .number 2>"$PR_VIEW_STDERR")
    PR_VIEW_EXIT=$?
    if [ "$PR_VIEW_EXIT" -ne 0 ]; then
        # gh pr view itself failed; do not silently treat as "no PR".
        # gh emits an explicit "no pull requests found" message in this same
        # error path, so check for that distinct case before falling back.
        if grep -qi "no pull requests found" "$PR_VIEW_STDERR" 2>/dev/null; then
            record_skip "Bot-cascade check (no PR open for branch)"
        else
            record_skip "Bot-cascade check (gh pr view failed, exit $PR_VIEW_EXIT)"
        fi
    elif [ -z "$PR_NUMBER" ]; then
        record_skip "Bot-cascade check (no PR open for branch)"
    else
        BOT_CHECK_OUTPUT=$(mktemp)
        BOT_CHECK_STDERR=$(mktemp)
        TEMP_FILES+=("$BOT_CHECK_OUTPUT" "$BOT_CHECK_STDERR")
        # Capture the exit code immediately after the command, then branch
        # on the saved variable (same robust pattern as PR_VIEW_EXIT and
        # REVIEW_API_EXIT). A later edit that inserts a command before the
        # `if` would otherwise clobber $? (cursor finding on PR #2011).
        "${PYTHON_CMD[@]}" \
            .claude/skills/github/scripts/pr/get_unresolved_review_threads.py \
            --pull-request "$PR_NUMBER" >"$BOT_CHECK_OUTPUT" 2>"$BOT_CHECK_STDERR"
        BOT_QUERY_EXIT=$?
        if [ "$BOT_QUERY_EXIT" -eq 0 ]; then
            # REQ-011-02: require BOTH success=true AND fetched_pages_complete=true
            # before trusting the count. Either failure produces SKIP, never PASS.
            UNRESOLVED_COUNT=$("${PYTHON_CMD[@]}" -c "
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    if not data.get('success', False):
        print('NOTSUCCESS')
    elif not data.get('fetched_pages_complete', False):
        print('INCOMPLETE')
    else:
        count = data.get('unresolved_count', 0)
        # Reject non-int, bool, or negative values. bool subclasses int in
        # Python, so a corrupted True/False payload would pass a plain
        # int-instance check (cursor finding on PR #2011). Any of these
        # would otherwise fall through to the zero-unresolved branch and
        # hide a bad payload as PASS (coderabbit P1 on PR #2011).
        # NB: no backticks in this comment; this code is passed to python
        # via bash -c inside a double-quoted string, where backticks would
        # trigger command substitution.
        if isinstance(count, bool) or not isinstance(count, int) or count < 0:
            print('ERROR')
        else:
            print(count)
except Exception:
    print('ERROR')
" "$BOT_CHECK_OUTPUT" 2>/dev/null || echo 'ERROR')
            if [ "$UNRESOLVED_COUNT" = "INCOMPLETE" ]; then
                record_skip "Bot-cascade check (PR #$PR_NUMBER snapshot incomplete: fetched_pages_complete=false)"
            elif [ "$UNRESOLVED_COUNT" = "NOTSUCCESS" ]; then
                record_skip "Bot-cascade check (PR #$PR_NUMBER thread query returned success=false)"
            elif [ "$UNRESOLVED_COUNT" = "ERROR" ]; then
                record_skip "Bot-cascade check (PR #$PR_NUMBER JSON parse failed)"
            elif [ "${UNRESOLVED_COUNT:-0}" -gt 0 ] 2>/dev/null; then
                # REQ-011-01: unresolved threads emit warn (not block).
                # NB: the unresolved count is total (not bot-filtered); the
                # underlying GraphQL query does not return author for each
                # thread. Labeled simply as "unresolved thread(s)" so the
                # message is accurate. See Issue #2012 for shape work and
                # downstream filtering proposals.
                record_warn "PR #$PR_NUMBER has $UNRESOLVED_COUNT unresolved thread(s)"
                echo_info "  Pushing now will trigger another bot scan and may"
                echo_info "  open more threads. Batch-fix pattern: resolve all"
                echo_info "  open threads first, then push one empty commit to"
                echo_info "  re-trigger CI."
                echo_info "  Bypass with: git push --no-verify"
            else
                # REQ-011-03: zero unresolved AND fetched_pages_complete=true
                # AND success=true. Check whether a bot review was submitted
                # in the last 120s. If so, warn (scan likely still in flight).
                # REQ-011-04: gh api failure is SKIP with explicit reason and
                # captured exit code. No `|| true` fall-through.
                REVIEW_STDERR=$(mktemp)
                TEMP_FILES+=("$REVIEW_STDERR")
                # The /reviews endpoint paginates at 30/page by default;
                # without --paginate, a bot review on page 2+ would be
                # missed and Phase 5c would report PASS while a scan is in
                # flight (coderabbit P1 on PR #2011). gh's --slurp is
                # incompatible with --jq, so instead use --paginate with a
                # per-page --jq that emits each bot review's submitted_at
                # (one timestamp per line across all pages), then sort and
                # take the newest in a separate step so $? reflects the gh
                # call, not the trailing sort/tail pipeline.
                REVIEW_RAW=$(gh api "repos/{owner}/{repo}/pulls/$PR_NUMBER/reviews" \
                    --paginate \
                    --jq '.[] | select(.user.type == "Bot") | .submitted_at' \
                    2>"$REVIEW_STDERR")
                REVIEW_API_EXIT=$?
                LAST_REVIEW_AGE_OUTPUT=$(printf '%s\n' "$REVIEW_RAW" | sort | tail -n 1)
                # Defensive: trim stray whitespace and double quotes to
                # harden against CLI version drift (gemini-code-assist
                # finding on PR #2011).
                LAST_REVIEW_AGE_OUTPUT=$(printf '%s' "$LAST_REVIEW_AGE_OUTPUT" | tr -d '"' | tr -d '[:space:]')
                if [ "$REVIEW_API_EXIT" -eq 0 ]; then
                    if [ -n "$LAST_REVIEW_AGE_OUTPUT" ] && [ "$LAST_REVIEW_AGE_OUTPUT" != "null" ]; then
                        # Parse the timestamp. On parse failure emit a
                        # distinguishable sentinel so we SKIP rather than
                        # PASS with bad data (coderabbit P1 on PR #2011).
                        AGE_SECONDS=$("${PYTHON_CMD[@]}" -c "
import sys
from datetime import datetime, timezone
try:
    ts = datetime.fromisoformat(sys.argv[1].replace('Z', '+00:00'))
    age = (datetime.now(timezone.utc) - ts).total_seconds()
    print(int(age))
except Exception:
    print('PARSE_ERROR')
" "$LAST_REVIEW_AGE_OUTPUT" 2>/dev/null || echo 'PARSE_ERROR')
                        if [ "$AGE_SECONDS" = "PARSE_ERROR" ]; then
                            record_skip "Bot-cascade check (PR #$PR_NUMBER timestamp parse failed for '$LAST_REVIEW_AGE_OUTPUT')"
                        elif [ "${AGE_SECONDS:-99999}" -lt 120 ] 2>/dev/null; then
                            record_warn "PR #$PR_NUMBER last bot review is ${AGE_SECONDS}s old (< 120s)"
                            echo_info "  A bot scan is likely still in flight. Threads"
                            echo_info "  may appear after this push. Wait at least 120s"
                            echo_info "  since the most recent bot review."
                            echo_info "  Bypass with: git push --no-verify"
                        else
                            record_pass "Bot-cascade check (PR #$PR_NUMBER, 0 unresolved, last bot review ${AGE_SECONDS}s old)"
                        fi
                    else
                        record_pass "Bot-cascade check (PR #$PR_NUMBER, 0 unresolved, no bot reviews)"
                    fi
                else
                    # REQ-011-04: gh api failed. SKIP and NAME THE FAILURE
                    # MODE (REQ-011 line 164 requires the SKIP message to
                    # classify the failure, with a special-case string for
                    # auth). Classify from captured stderr; fall back to the
                    # exit code. No `|| true` fall-through; auth/network/
                    # rate-limit failures must not mask in-flight reviews
                    # as PASS.
                    REVIEW_FAIL_MODE="unclassified"
                    if [ -s "$REVIEW_STDERR" ]; then
                        # Specific auth signals only. A bare 'auth' alternative
                        # would match 'author' as a substring and misclassify
                        # unrelated errors (copilot finding on PR #2011). gh
                        # emits 'HTTP 401'/'HTTP 403' for auth failures.
                        if grep -qiE 'unauthorized|authentication|bad credentials|gh auth login|HTTP 401|HTTP 403' "$REVIEW_STDERR" 2>/dev/null; then
                            REVIEW_FAIL_MODE="gh api auth failed"
                        elif grep -qiE 'rate limit|429|secondary rate' "$REVIEW_STDERR" 2>/dev/null; then
                            REVIEW_FAIL_MODE="gh api rate-limited"
                        elif grep -qiE 'could not resolve|network|connection|timeout|temporary failure|dns' "$REVIEW_STDERR" 2>/dev/null; then
                            REVIEW_FAIL_MODE="gh api network error"
                        fi
                    fi
                    # Exit code appended once; REVIEW_FAIL_MODE never contains
                    # the exit code itself (cursor finding on PR #2011: a prior
                    # default of "exit $REVIEW_API_EXIT" produced "..., exit N,
                    # exit N").
                    record_skip "Bot-cascade check (PR #$PR_NUMBER gh api reviews failed: $REVIEW_FAIL_MODE, exit $REVIEW_API_EXIT)"
                fi
            fi
        else
            record_skip "Bot-cascade check (get_unresolved_review_threads.py failed for PR #$PR_NUMBER, exit $BOT_QUERY_EXIT)"
        fi
    fi
fi

