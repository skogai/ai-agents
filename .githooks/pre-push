# 11b. Build pipeline staleness (build_all.py --check)
#
# Catches generator drift the CI "Validate Generated Files" gate would
# otherwise reject (~90s + bot-rescan cost). Local cost is sub-second.
# Fires unconditionally; build_all.py covers agents, skills, commands,
# rules->instructions, and hooks->copilot. PR #1897 round 6 staleness
# failure on .github/instructions/canonical-source-mirror.instructions.md
# is the canonical example this guards against.
BUILD_ALL_SCRIPT="$REPO_ROOT/build/scripts/build_all.py"

if [ -L "$BUILD_ALL_SCRIPT" ]; then
    record_warn "build_all.py is a symlink (skipping)"
elif [ -f "$BUILD_ALL_SCRIPT" ]; then
    # Use set_python_cmd (uv-aware) instead of bare python3:
    # build_all.py imports yaml (PyYAML via build/yaml_loader.py), a
    # third-party package typically only available inside the project's
    # venv. Bare python3 raises ImportError and the hook misreports it
    # as "staleness detected" instead of the real "PyYAML not in
    # system Python" diagnosis. Pattern matches Phase-2/4 sites
    # (workflow validation L476, pytest L635, semgrep L674).
    if set_python_cmd; then
        BUILD_ALL_OUTPUT=$(mktemp)
        TEMP_FILES+=("$BUILD_ALL_OUTPUT")
        "${PYTHON_CMD[@]}" "$BUILD_ALL_SCRIPT" --check > "$BUILD_ALL_OUTPUT" 2>&1
        BUILD_ALL_RC=$?
        if [ $BUILD_ALL_RC -eq 0 ]; then
            record_pass "Build pipeline staleness (build_all.py --check)"
        else
            # Branch on whether the failure carries STALENESS markers.
            # Each branch picks BOTH the output filter AND the message
            # together so the user sees the right output for the right
            # failure. The earlier `grep ... | head -20 || head -20`
            # fallback is broken: head -20 always exits 0 (it succeeds
            # on empty stdin), so the `||` branch is dead code. Issue
            # #1924 tracks the same bug at L359 (markdown-lint pattern
            # this section was originally modeled on).
            echo_info "  build_all.py --check output:"
            if grep -qE "STALENESS DETECTED" "$BUILD_ALL_OUTPUT" 2>/dev/null; then
                # Staleness path: filter to header + indented stale-file
                # paths (build_all.py prints stale paths indented two
                # spaces; verified locally on PR #1915 round 3).
                grep -E "STALENESS|^  [./]" "$BUILD_ALL_OUTPUT" | head -20
                record_fail "Build pipeline staleness detected (exit $BUILD_ALL_RC)"
                echo_info "  Fix: ${PYTHON_CMD[*]} build/scripts/build_all.py"
                echo_info "  Then commit the regenerated files."
            else
                # Non-staleness path: show unfiltered head so the actual
                # failure (ImportError on missing PyYAML, exit 2 from
                # config-load error, broken generator stanza) is visible.
                head -20 "$BUILD_ALL_OUTPUT"
                record_fail "Build pipeline check failed (exit $BUILD_ALL_RC; not staleness)"
                echo_info "  Fix: investigate the output above; staleness markers absent."
                echo_info "  Common causes: missing PyYAML in active Python; build_all"
                echo_info "  config-load error (exit 2); broken generator stanza."
            fi
        fi
        rm -f "$BUILD_ALL_OUTPUT"
    else
        record_skip "Build pipeline staleness (no Python available)"
    fi
else
    record_skip "Build pipeline staleness (script not found)"
fi

# 11c. Plugin version bump (validate_plugin_version_bump.py)
#
# Fails when a packaged plugin's source dir (.claude, src/claude,
# src/copilot-cli) changed in this push without a strictly-greater
# plugin.json version bump. Installed caches key off the version; an
# unbumped version means the change never reaches consumers (PR #1942 /
# PR #2114, Issue #2118). Same validator the CI gate and the PreToolUse
# guard use, so all three agree.
#
# Validates each ref being pushed (not just the last one) by iterating
# over PVB_BASES/PVB_HEADS arrays populated during ref processing. Uses
# --head to validate the specific commit being pushed, not the working
# tree or HEAD, so uncommitted changes cannot mask missing bumps.
PLUGIN_VERSION_SCRIPT="$REPO_ROOT/build/scripts/validate_plugin_version_bump.py"

if [ -L "$PLUGIN_VERSION_SCRIPT" ]; then
    record_warn "Plugin version bump script is a symlink (skipping)"
elif [ -f "$PLUGIN_VERSION_SCRIPT" ] && [ ${#PVB_BASES[@]} -gt 0 ]; then
    if set_python_cmd; then
        # Issue #2453: refresh origin/<branch> bases before validating so a stale
        # local ref does not false-PASS a bump that is actually insufficient
        # against the real remote. Best-effort; failure does not block.
        PVB_FETCHED=()
        for pvb_base in "${PVB_BASES[@]}"; do
            case "$pvb_base" in
                origin/*)
                    branch="${pvb_base#origin/}"
                    case "$branch" in ""|*/*) continue;; esac
                    already_fetched=0
                    for f in "${PVB_FETCHED[@]}"; do
                        if [ "$f" = "$branch" ]; then already_fetched=1; break; fi
                    done
                    if [ $already_fetched -eq 0 ]; then
                        if ! env -u GIT_DIR -u GIT_WORK_TREE -u GIT_COMMON_DIR -u GIT_INDEX_FILE \
                            LC_ALL=C git fetch --no-tags --quiet origin "$branch" 2>/dev/null; then
                            echo_info "  [WARN] could not refresh origin/$branch; continuing with stale local ref (#2453)"
                        fi
                        PVB_FETCHED+=("$branch")
                    fi
                    ;;
            esac
        done

        PVB_ALL_PASSED=1
        PVB_ANY_CONFIG_ERROR=0
        for i in "${!PVB_BASES[@]}"; do
            pvb_base="${PVB_BASES[$i]}"
            pvb_head="${PVB_HEADS[$i]}"
            PVB_OUTPUT=$(mktemp)
            TEMP_FILES+=("$PVB_OUTPUT")
            "${PYTHON_CMD[@]}" "$PLUGIN_VERSION_SCRIPT" \
                --base "$pvb_base" --head "$pvb_head" \
                > "$PVB_OUTPUT" 2>&1
            PVB_RC=$?
            if [ $PVB_RC -eq 0 ]; then
                : # Pass for this ref, continue checking others
            elif [ $PVB_RC -eq 2 ]; then
                head -20 "$PVB_OUTPUT"
                PVB_ANY_CONFIG_ERROR=1
            else
                cat "$PVB_OUTPUT"
                PVB_ALL_PASSED=0
            fi
            rm -f "$PVB_OUTPUT"
        done
        if [ $PVB_ALL_PASSED -eq 1 ] && [ $PVB_ANY_CONFIG_ERROR -eq 0 ]; then
            record_pass "Plugin version bump"
        elif [ $PVB_ANY_CONFIG_ERROR -eq 1 ] && [ $PVB_ALL_PASSED -eq 1 ]; then
            record_warn "Plugin version bump check config error (exit 2)"
        else
            record_fail "Plugin source changed without version bump"
            echo_info "  Fix: bump 'version' in the reported"
            echo_info "  .claude-plugin/plugin.json to a higher semver, then commit."
        fi
    else
        record_skip "Plugin version bump (no Python available)"
    fi
elif [ ! -f "$PLUGIN_VERSION_SCRIPT" ]; then
    record_skip "Plugin version bump (script not found)"
else
    record_skip "Plugin version bump (no refs to validate)"
fi

