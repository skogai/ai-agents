{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/invoke_routing_gates.py",
            "timeout": 5,
            "statusMessage": "Checking routing-level gates (ADR-033)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_skill_first_guard.py",
            "statusMessage": "Enforcing skills-first policy for GitHub operations (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_correction_applier.py",
            "timeout": 3,
            "statusMessage": "Checking correction memories (Self-Improving Agent)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_false_completion_gate.py",
            "timeout": 5,
            "statusMessage": "Checking for false completion claims without verification (#1703)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_bash_grep_guard.py",
            "timeout": 5,
            "statusMessage": "Enforcing LSP-first over bash grep on code symbols (ADR-062, conditional)"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*|git ci*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_session_log_guard.py",
            "statusMessage": "Verifying session log exists before commit (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_branch_context_guard.py",
            "statusMessage": "Verifying branch matches session context (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_adr_review_guard.py",
            "statusMessage": "Verifying ADR review completed (MUST requirement)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_branch_protection_guard.py",
            "statusMessage": "Verifying branch protection"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_security_commit_gate.py",
            "timeout": 10,
            "statusMessage": "Checking security gate for staged auth files (ADR-033)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_prompt_eval_gate.py",
            "timeout": 10,
            "statusMessage": "Checking ADR-057 behavioral eval evidence for prompt changes"
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_session_log_guard.py",
            "statusMessage": "Verifying session log exists before PR creation (BLOCKING)"
          }
        ]
      },
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_security_gate.py",
            "statusMessage": "Checking security gate for auth files (ADR-033)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_topical_memory_injection.py",
            "timeout": 2,
            "statusMessage": "Surfacing topical memories (advisory, issue #2005)"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_branch_context_guard.py",
            "statusMessage": "Verifying branch matches session context (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_branch_protection_guard.py",
            "statusMessage": "Verifying branch protection"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_retrospective_gate.py",
            "statusMessage": "Verifying retrospective evidence (ADR-033)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_markdownlint_guard.py",
            "timeout": 90,
            "statusMessage": "Checking markdownlint violations on changed .md files (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_session_log_field_guard.py",
            "statusMessage": "Checking session log placeholder values (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_pr_description_guard.py",
            "timeout": 90,
            "statusMessage": "Checking PR description vs diff (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_install_parity_guard.py",
            "timeout": 30,
            "statusMessage": "Checking install-copy parity for agents and rules (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_plugin_version_bump_guard.py",
            "timeout": 30,
            "statusMessage": "Checking plugin.json version bump on plugin source change (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_hook_drift_guard.py",
            "timeout": 30,
            "statusMessage": "Checking hook generator drift in src/copilot-cli/hooks/ (BLOCKING)"
          }
        ]
      },
      {
        "matcher": "^(Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_adr_architect_gate.py",
            "statusMessage": "Verifying architect review for ADR files (BLOCKING)"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_grep_guard.py",
            "timeout": 5,
            "statusMessage": "Enforcing LSP-first over Grep on code symbols (ADR-062, conditional)"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_glob_guard.py",
            "timeout": 5,
            "statusMessage": "Enforcing LSP-first over symbol-shaped Glob (ADR-062, conditional)"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_read_guard.py",
            "timeout": 5,
            "statusMessage": "Enforcing LSP-first navigation before code Read (ADR-062, graduated)"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_pre_delegation_guard.py",
            "timeout": 5,
            "statusMessage": "Requiring pre-resolved LSP context for delegated implementation agents (ADR-062)"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/invoke_lsp_pre_delegation_guard.py",
            "timeout": 5,
            "statusMessage": "Requiring pre-resolved LSP context for delegated implementation agents (ADR-062)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/session-start.sh",
            "timeout": 900,
            "statusMessage": "Installing project dependencies (matches CI)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/invoke_session_initialization_enforcer.py",
            "statusMessage": "Enforcing session protocol initialization (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/invoke_memory_first_enforcer.py",
            "statusMessage": "Enforcing ADR-007 memory-first evidence (HYBRID)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/invoke_session_start_memory_first.py",
            "statusMessage": "Enforcing ADR-007 memory-first requirements"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/invoke_adr_change_detection.py",
            "statusMessage": "Checking for ADR changes"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/invoke_context_loader.py",
            "statusMessage": "Auto-loading HANDOFF.md and latest retrospective (#1703)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/invoke_lsp_session_reset.py",
            "timeout": 5,
            "statusMessage": "Resetting LSP-gate state for the new session (ADR-062)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/UserPromptSubmit/invoke_serena_reassertion.py",
            "timeout": 3,
            "statusMessage": "Re-asserting Serena activation (issue #1993)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/UserPromptSubmit/invoke_autonomous_execution_detector.py",
            "statusMessage": "Detecting autonomous execution patterns"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/UserPromptSubmit/invoke_research_then_implement.py",
            "timeout": 3,
            "statusMessage": "Checking for research-before-implementation signals"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/invoke_user_prompt_memory_check.py",
            "statusMessage": "Checking memory-first compliance"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_markdown_auto_lint.py",
            "statusMessage": "Auto-linting markdown files"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_adr_lifecycle_hook.py",
            "statusMessage": "Checking for ADR changes"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_plan_state_sync.py",
            "statusMessage": "Checkpointing plan/TODO state (#1703)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_adr_lifecycle_hook.py",
            "statusMessage": "Checking for ADR changes"
          }
        ]
      },
      {
        "matcher": "mcp__serena__write_memory",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_observation_sync.py",
            "timeout": 30,
            "statusMessage": "Syncing observation memories to Forgetful"
          }
        ]
      },
      {
        "matcher": "^(mcp__serena__(find_symbol|find_referencing_symbols|get_symbols_overview|find_implementations|get_diagnostics_for_file)|mcp__plugin_[^_]*serena[^_]*__(find_symbol|find_referencing_symbols|get_symbols_overview|find_implementations|get_diagnostics_for_file)|LSP)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_lsp_usage_tracker.py",
            "timeout": 5,
            "statusMessage": "Tracking LSP navigation calls for the LSP-first gate (ADR-062)"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/invoke_lsp_read_tracker.py",
            "timeout": 5,
            "statusMessage": "Tracking Read operations for the LSP-first gate (ADR-062)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/Stop/invoke_skill_learning.py",
            "statusMessage": "Extracting skill learnings from session (LLM-enhanced)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/Stop/invoke_session_validator.py",
            "statusMessage": "Validating session completeness"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/Stop/invoke_auto_retrospective.py",
            "statusMessage": "Auto-generating session retrospective (#1703)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SubagentStop/invoke_qa_agent_validator.py",
            "statusMessage": "Validating QA agent output"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreCompact/invoke_compact_checkpoint.py",
            "statusMessage": "Checkpointing state before compaction (#1703)"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash(pwsh*Invoke-Pester*|npm test*|npm run test*|pnpm test*|yarn test*|pytest*|python*pytest*|dotnet test*|mvn test*|gradle test*|go test*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PermissionRequest/invoke_test_auto_approval.py",
            "statusMessage": "Auto-approving test execution"
          }
        ]
      }
    ]
  }
}
